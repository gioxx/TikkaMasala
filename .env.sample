# TikkaMasala sample environment file
# Copy to .env and replace the placeholder values.

# Optional: prefill the Cloudflare account ID in the UI.
CLOUDFLARE_ACCOUNT_ID=your-32-char-account-id

# Optional: prefill the Cloudflare API token in the UI.
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Recommended if you want the API token persisted encrypted in ./data/app.db.
# Generate with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your-generated-fernet-key

# Optional: force automatic backups to use a specific IANA timezone.
# Example: Europe/Rome, UTC, America/New_York
AUTO_BACKUP_TIMEZONE=Europe/Rome

# Optional: automatically delete backup files and DB records older than this many days.
# Cleanup runs after new backups are created. Leave empty to disable retention.
BACKUP_RETENTION_DAYS=90

# Optional: send JSON notifications to a generic webhook endpoint.
# Example events: manual_backup_success, manual_backup_failed, auto_backup_success,
# auto_backup_partial, auto_backup_failed, restore_success, restore_failed, retention_cleanup
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_EVENTS=auto_backup_success,auto_backup_partial,auto_backup_failed,restore_failed,retention_cleanup

# Optional: send notifications to Telegram in addition to, or instead of, a webhook.
# Create a bot with BotFather and use your chat ID or group/channel chat ID here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFICATION_EVENTS=auto_backup_success,auto_backup_partial,auto_backup_failed,restore_failed,retention_cleanup

# Optional runtime settings.
DATA_DIR=/data
REQUEST_TIMEOUT=20
LOG_LEVEL=INFO
CLOUDFLARE_API_BASE=https://api.cloudflare.com/client/v4
